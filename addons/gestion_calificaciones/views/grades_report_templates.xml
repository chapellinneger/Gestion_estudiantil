<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Report Action for Grades -->
    <record id="action_report_grades_pdf" model="ir.actions.report">
        <field name="name">Reporte de Calificaciones (PDF)</field>
        <field name="model">gestion.export</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">gestion_calificaciones.report_grades_template</field>
        <field name="report_file">gestion_calificaciones.report_grades_template</field>
        <field name="binding_model_id" eval="False"/>
        <field name="binding_type">report</field>
    </record>

    <!-- Main Grades Report Template -->
    <template id="report_grades_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.internal_layout">
                    <!-- Custom Styles for Premium Presentation -->
                    <style>
                        .report-container {
                            font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
                            color: #2C3E50;
                        }
                        .report-header-title {
                            color: #2980B9;
                            font-size: 26px;
                            font-weight: 700;
                            margin-bottom: 25px;
                            text-align: center;
                            text-transform: uppercase;
                            border-bottom: 3px solid #2C3E50;
                            padding-bottom: 12px;
                        }
                        .info-card {
                            background-color: #F8F9FA;
                            border: 1px solid #E2E8F0;
                            border-radius: 6px;
                            padding: 15px;
                            margin-bottom: 30px;
                        }
                        .info-label {
                            font-weight: bold;
                            color: #34495E;
                            font-size: 13px;
                        }
                        .info-val {
                            font-size: 13px;
                            color: #2C3E50;
                        }
                        .report-section-title {
                            font-size: 18px;
                            font-weight: 600;
                            color: #2C3E50;
                            margin-top: 30px;
                            margin-bottom: 15px;
                            border-left: 5px solid #2980B9;
                            padding-left: 12px;
                        }
                        .table-premium {
                            width: 100%;
                            border-collapse: collapse;
                            margin-bottom: 25px;
                            font-size: 12px;
                        }
                        .table-premium th {
                            background-color: #2C3E50;
                            color: #FFFFFF !important;
                            font-weight: 600;
                            text-transform: uppercase;
                            font-size: 11px;
                            padding: 8px 10px;
                            border: 1px solid #34495E;
                            text-align: center;
                        }
                        .table-premium td {
                            padding: 8px 10px;
                            border: 1px solid #E2E8F0;
                            vertical-align: middle;
                        }
                        .table-premium tr:nth-child(even) td {
                            background-color: #F8F9FA;
                        }
                        .badge-passing {
                            background-color: #D4EDDA;
                            color: #155724;
                            border: 1px solid #C3E6CB;
                            padding: 3px 8px;
                            border-radius: 4px;
                            font-weight: 600;
                            font-size: 11px;
                            display: inline-block;
                        }
                        .badge-failing {
                            background-color: #F8D7DA;
                            color: #721C24;
                            border: 1px solid #F5C6CB;
                            padding: 3px 8px;
                            border-radius: 4px;
                            font-weight: 600;
                            font-size: 11px;
                            display: inline-block;
                        }
                        .text-ratio {
                            font-weight: bold;
                            color: #2980B9;
                        }
                    </style>

                    <div class="page report-container">
                        <!-- Header / Title -->
                        <div class="report-header-title">
                            Reporte de Calificaciones de Estudiantes
                        </div>

                        <!-- Info Card / Parameters -->
                        <div class="info-card">
                            <div class="row">
                                <div class="col-6">
                                    <table class="table table-sm table-borderless mb-0">
                                        <tr>
                                            <td class="info-label" style="width: 40%; padding: 2px 0;">Filtro utilizado:</td>
                                            <td class="info-val" style="padding: 2px 0;">
                                                <t t-if="doc.filter_type == 'all'">Todos los estudiantes</t>
                                                <t t-elif="doc.filter_type == 'single' and doc.student_id">
                                                    Estudiante: <span t-field="doc.student_id.name"/>
                                                </t>
                                                <t t-elif="doc.filter_type == 'section' and doc.section_id">
                                                    Sección: <span t-field="doc.section_id.name"/>
                                                </t>
                                                <t t-elif="doc.filter_type == 'subject' and doc.subject_id">
                                                    Materia: <span t-field="doc.subject_id.name"/>
                                                </t>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td class="info-label" style="padding: 2px 0;">Materia:</td>
                                            <td class="info-val" style="padding: 2px 0;">
                                                <span t-out="doc.subject_id.name or 'Todas las materias'"/>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td class="info-label" style="padding: 2px 0;">Fecha Generación:</td>
                                            <td class="info-val" style="padding: 2px 0;">
                                                <span t-out="doc.get_today_date()"/>
                                            </td>
                                        </tr>
                                    </table>
                                </div>
                                <div class="col-6">
                                    <table class="table table-sm table-borderless mb-0">
                                        <tr>
                                            <td class="info-label" style="width: 40%; padding: 2px 0;">Fecha Desde:</td>
                                            <td class="info-val" style="padding: 2px 0;">
                                                <span t-out="doc.date_from or 'Inicio'"/>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td class="info-label" style="padding: 2px 0;">Fecha Hasta:</td>
                                            <td class="info-val" style="padding: 2px 0;">
                                                <span t-out="doc.date_to or 'Fin'"/>
                                            </td>
                                        </tr>
                                    </table>
                                </div>
                            </div>
                        </div>

                        <!-- Data retrieval -->
                        <t t-set="lines" t-value="doc.get_grade_lines()"/>
                        <t t-set="students" t-value="lines.mapped('student_id')"/>

                        <!-- SECTION 1: RESUMEN DE CALIFICACIONES -->
                        <div class="report-section-title">Resumen de Calificaciones</div>
                        <t t-if="students">
                            <table class="table-premium">
                                <thead>
                                    <tr>
                                        <th>Estudiante</th>
                                        <th style="width: 20%;">Matrícula</th>
                                        <th style="width: 25%;">Actividades Evaluadas</th>
                                        <th style="width: 25%;">Promedio General</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="students" t-as="student">
                                        <t t-set="student_lines" t-value="lines.filtered(lambda l: l.student_id == student)"/>
                                        <t t-set="avg_score" t-value="doc.get_student_average(student, student_lines)"/>
                                        <t t-set="total_act" t-value="doc.get_student_total_activities(student, student_lines)"/>
                                        
                                        <tr>
                                            <td><span t-field="student.name"/></td>
                                            <td class="text-center"><span t-field="student.enrollment_number"/></td>
                                            <td class="text-center"><span t-out="total_act"/></td>
                                            <td class="text-center">
                                                <t t-if="avg_score &gt;= 10">
                                                    <span class="badge-passing"><t t-out="'%.2f' % avg_score"/></span>
                                                </t>
                                                <t t-else="">
                                                    <span class="badge-failing"><t t-out="'%.2f' % avg_score"/></span>
                                                </t>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>
                        <t t-else="">
                            <div class="alert alert-info text-center" style="font-size: 13px;">
                                No hay datos de resumen de calificaciones disponibles para los criterios seleccionados.
                            </div>
                        </t>

                        <!-- Page break for details -->
                        <div style="page-break-before: always;"/>

                        <!-- SECTION 2: DETALLE DE CALIFICACIONES -->
                        <div class="report-section-title">Detalle de Calificaciones</div>
                        <t t-if="lines">
                            <table class="table-premium">
                                <thead>
                                    <tr>
                                        <th>Estudiante</th>
                                        <th style="width: 22%;">Materia</th>
                                        <th style="width: 22%;">Actividad</th>
                                        <th style="width: 12%;">Calificación</th>
                                        <th style="width: 12%;">Fecha</th>
                                        <th style="width: 22%;">Observaciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="lines" t-as="line">
                                        <tr>
                                            <td><span t-field="line.student_id.name"/></td>
                                            <td class="text-center"><span t-field="line.activity_id.subject_id.name"/></td>
                                            <td><span t-field="line.activity_id.name"/></td>
                                            <td class="text-center">
                                                <t t-if="line.score &gt;= 10">
                                                    <span class="badge-passing"><t t-out="'%.2f' % line.score"/></span>
                                                </t>
                                                <t t-else="">
                                                    <span class="badge-failing"><t t-out="'%.2f' % line.score"/></span>
                                                </t>
                                            </td>
                                            <td class="text-center"><span t-field="line.date" t-options='{"widget": "date"}'/></td>
                                            <td><span t-field="line.teacher_feedback"/></td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>
                        <t t-else="">
                            <div class="alert alert-info text-center" style="font-size: 13px;">
                                No hay detalles de calificaciones que mostrar.
                            </div>
                        </t>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
