<odoo>
  <data>

    <record id="view_student_grade_list" model="ir.ui.view">
      <field name="name">gestion.student.grade.list</field>
      <field name="model">gestion.student.grade</field>
      <field name="arch" type="xml">
        <list create="false" edit="false" delete="false">
          <field name="student_id"/>
          <field name="activity_id"/>
          <field name="score"/>
          <field name="date"/>
          <field name="description"/>
        </list>
      </field>
    </record>

    <record id="view_student_grade_form" model="ir.ui.view">
      <field name="name">gestion.student.grade.form</field>
      <field name="model">gestion.student.grade</field>
      <field name="arch" type="xml">
        <form create="false" edit="false" delete="false">
          <sheet>
            <group>
              <field name="student_id"/>
              <field name="activity_id"/>
              <field name="score"/>
              <field name="date"/>
            </group>
            <group>
              <field name="description"/>
            </group>
          </sheet>
        </form>
      </field>
    </record>

    <record id="action_student_grade" model="ir.actions.act_window">
      <field name="name">Historial de Calificaciones</field>
      <field name="res_model">gestion.student.grade</field>
      <field name="view_mode">list,form</field>
    </record>

  </data>
</odoo>