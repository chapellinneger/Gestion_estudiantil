<odoo>
    <record id="view_gestion_seccion_tree" model="ir.ui.view">
        <field name="name">gestion.seccion.tree</field>
        <field name="model">gestion.seccion</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="subject_id"/>
                <field name="teacher_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_gestion_seccion_form" model="ir.ui.view">
        <field name="name">gestion.seccion.form</field>
        <field name="model">gestion.seccion</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="subject_id"/>
                        <field name="teacher_id"/>
                        <field name="state"/>
                    </group>

                    <group string="Estudiantes">
                        <field name="student_ids" widget="many2many_tags"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>