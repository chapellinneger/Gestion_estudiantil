<odoo>
    <record id="view_gestion_seccion_list" model="ir.ui.view">
        <field name="name">gestion.seccion.tree</field>
        <field name="model">gestion.seccion</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="subject_id"/>
                <field name="teacher_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_gestion_seccion_form" model="ir.ui.view">
        <field name="name">gestion.seccion.form</field>
        <field name="model">gestion.seccion</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="subject_id"/>
                        <field name="teacher_id"/>
                        <field name="state"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_gestion_seccion" model="ir.actions.act_window">
        <field name="name">Secciones</field>
        <field name="res_model">gestion.seccion</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
