<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_gestion_tipo_evaluacion_form" model="ir.ui.view">
        <field name="name">gestion.tipo.evaluacion.form</field>
        <field name="model">gestion.tipo.evaluacion</field>
        <field name="arch" type="xml">
            <form string="Tipo de Evaluación">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="seccion_id"/>
                        <field name="porcentaje"/>
                        <field name="periodo_id" domain="[('activo', '=', True)]"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_gestion_tipo_evaluacion_tree" model="ir.ui.view">
        <field name="name">gestion.tipo.evaluacion.tree</field>
        <field name="model">gestion.tipo.evaluacion</field>
        <field name="arch" type="xml">
            <tree string="Tipos de Evaluación">
                <field name="name"/>
                <field name="seccion_id"/>
                <field name="porcentaje"/>
                <field name="periodo_id"/>
            </tree>
        </field>
    </record>

    <record id="action_gestion_tipo_evaluacion" model="ir.actions.act_window">
        <field name="name">Tipos de Evaluación</field>
        <field name="res_model">gestion.tipo.evaluacion</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p>Defina aquí los tipos de evaluación con sus porcentajes por sección.</p>
        </field>
    </record>
</odoo>