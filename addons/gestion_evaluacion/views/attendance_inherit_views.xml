<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_gestion_attendance_form_inherit" model="ir.ui.view">
        <field name="name">gestion.attendance.form.inherit</field>
        <field name="model">gestion.attendance</field>
        <field name="inherit_id" ref="gestion_estudiantil.view_gestion_attendance_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='section_id']" position="after">
                <field name="tipo_evaluacion_id" 
                       domain="[('seccion_id', '=', section_id)]" 
                       options="{'no_create': True, 'no_open': True}"
                       invisible="not section_id"/>
            </xpath>
        </field>
    </record>
</odoo>
