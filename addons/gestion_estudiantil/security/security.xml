<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_gestion_estudiantil" model="ir.module.category">
        <field name="name">Gestión Estudiantil</field>
    </record>

    <record id="group_estudiante" model="res.groups">
        <field name="name">Estudiante</field>
        <field name="category_id" ref="module_category_gestion_estudiantil"/>
        <field name="implied_ids" eval="[(6, 0, [ref('base.group_portal')])]"/>
    </record>
    
    <record id="rule_estudiante_leer_partner_profesor" model="ir.rule">
        <field name="name">Estudiante puede ver datos de contacto de Profesores</field>
        <field name="model_id" ref="base.model_res_partner"/>
        <field name="domain_force">[('is_teacher', '=', True)]</field>
        <field name="groups" eval="[(4, ref('gestion_estudiantil.group_estudiante'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_estudiante_leer_gestion_teacher" model="ir.rule">
        <field name="name">Estudiante puede leer modelo Teacher</field>
        <field name="model_id" ref="gestion_profesorado.model_gestion_teacher"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('gestion_estudiantil.group_estudiante'))]"/>
    </record>
    
    <record id="rule_attendance_teacher_only" model="ir.rule">
        <field name="name">Asistencias: Profesores solo ven las suyas</field>
        <field name="model_id" ref="model_gestion_attendance"/>
        <field name="domain_force">[('teacher_id.user_ids', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('gestion_profesorado.group_profesor'))]"/>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="1"/>
        <field name="perm_unlink" eval="1"/>
    </record>
    <record id="rule_seccion_teacher_only" model="ir.rule">
        <field name="name">Secciones: Profesores solo ven las suyas (Lectura)</field>
        <field name="model_id" ref="gestion_secciones.model_gestion_seccion"/>
        <field name="domain_force">[('teacher_id.user_ids', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('gestion_profesorado.group_profesor'))]"/>
        
        <field name="perm_read" eval="1"/>    
        <field name="perm_write" eval="0"/>   
        <field name="perm_create" eval="0"/>  
        <field name="perm_unlink" eval="0"/>  
        </record>

    <!-- ============================================================ -->
    <!-- REGLAS DE SEGURIDAD PARA PARTICIPACIÓN EN CLASE              -->
    <!-- ============================================================ -->

    <!-- Profesores: solo ven sus propias sesiones de participación -->
    <record id="rule_participacion_teacher_only" model="ir.rule">
        <field name="name">Participación: Profesores solo ven las suyas</field>
        <field name="model_id" ref="model_gestion_participacion_clase"/>
        <field name="domain_force">[('teacher_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('gestion_profesorado.group_profesor'))]"/>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="1"/>
        <field name="perm_unlink" eval="1"/>
    </record>

    <!-- Profesores: solo ven líneas de sus propias sesiones -->
    <record id="rule_participacion_line_teacher_only" model="ir.rule">
        <field name="name">Participación Línea: Profesores solo ven las suyas</field>
        <field name="model_id" ref="model_gestion_participacion_line"/>
        <field name="domain_force">[('participacion_id.teacher_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('gestion_profesorado.group_profesor'))]"/>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="1"/>
        <field name="perm_unlink" eval="1"/>
    </record>
</odoo>