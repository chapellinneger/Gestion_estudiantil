<odoo>
  <data>
    <!-- Explicit list view definition -->
    <record model="ir.ui.view" id="gestion_estudiantil.student_list">
      <field name="name">gestion_estudiantil.student.list</field>
      <field name="model">gestion_estudiantil.student</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="description"/>
          <field name="active"/>
        </list>
      </field>
    </record>

    <!-- Form view -->
    <record model="ir.ui.view" id="gestion_estudiantil.student_form">
      <field name="name">gestion_estudiantil.student.form</field>
      <field name="model">gestion_estudiantil.student</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <group>
              <field name="name"/>
              <field name="description"/>
              <field name="active"/>
            </group>
          </sheet>
        </form>
      </field>
    </record>

    <!-- Actions -->
    <record model="ir.actions.act_window" id="gestion_estudiantil.action_window">
      <field name="name">Estudiantes</field>
      <field name="res_model">gestion_estudiantil.student</field>
      <field name="view_mode">list,form</field>
    </record>

    <!-- Menu items -->
    <menuitem name="Gestion Estudiantil" id="gestion_estudiantil.menu_root"/>
    <menuitem name="Estudiantes" id="gestion_estudiantil.menu_1" parent="gestion_estudiantil.menu_root" action="gestion_estudiantil.action_window"/>
  </data>
</odoo>
