<odoo>
    <record id="view_users_form_inherit_estudiantil" model="ir.ui.view">
        <field name="name">res.users.form.inherit.estudiantil</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='access_rights']" position="after">
                <page string="Portal del Estudiante" name="student_portal">
                    <group>
                        <group string="Información General">
                            <field name="enrollment_number"/>
                        </group>
                    </group>
                    <group string="Historial Académico">
                        <field name="academic_history"/>
                    </group>
                    </page>
            </xpath>
        </field>
    </record>

    <record id="action_estudiantes_final" model="ir.actions.act_window">
        <field name="name">Estudiantes</field>
        <field name="res_model">res.users</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('enrollment_number', '!=', False)]</field>
    </record>

    <menuitem id="menu_estudiantil_root" name="Gestión Estudiantil" sequence="1"/>
    <menuitem id="menu_estudiantes_main" name="Estudiantes" parent="menu_estudiantil_root" action="action_estudiantes_final"/>
</odoo>