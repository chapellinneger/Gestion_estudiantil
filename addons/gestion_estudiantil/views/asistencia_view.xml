<odoo>
    <record id="view_gestion_attendance_list" model="ir.ui.view">
        <field name="name">gestion.attendance.list</field>
        <field name="model">gestion.attendance</field>
        <field name="arch" type="xml">
            <list string="Asistencias">
                <field name="date"/>
                <field name="subject_id"/> <field name="section_id"/>
                <field name="teacher_id"/> <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'confirmed'"/>
            </list>
        </field>
    </record>

    <record id="view_gestion_attendance_form" model="ir.ui.view">
        <field name="name">gestion.attendance.form</field>
        <field name="model">gestion.attendance</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm" string="Confirmar" type="object" invisible="state == 'confirmed'" class="oe_highlight"/>
                    <field name="state" widget="statusbar"/>
            </header>
            <sheet>
                <group>
                    <group>
                        <field name="date"/>
                        <field name="subject_id" domain="[('teacher_id.user_ids', '=', uid)]"/>
                        
                        <field name="section_id" 
                               domain="[('subject_id', '=', subject_id), ('teacher_id.user_ids', '=', uid)]" 
                               invisible="not subject_id"/>
                    </group>
                    <group>
                        <field name="teacher_id" options="{'no_open': True, 'no_create': True}"/>
                    </group>
                    <group>
                        <field name="estado_periodo_materia" 
                               widget="badge" 
                               decoration-success="estado_periodo_materia == 'abierto'" 
                               decoration-danger="estado_periodo_materia == 'cerrado'"
                               invisible="not subject_id"/>
                    </group>

                </group>
                <notebook>
                        <page string="Lista de Estudiantes">
                            <field name="attendance_line_ids" readonly="state == 'confirmed'">
                                <list editable="bottom">
                                    <field name="student_id"/>
                                    <field name="present"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_gestion_attendance" model="ir.actions.act_window">
        <field name="name">Asistencia</field>
        <field name="res_model">gestion.attendance</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_gestion_attendance" 
              name="Registro de Asistencia" 
              parent="menu_estudiantil_root" 
              action="action_gestion_attendance" 
              sequence="10"/>
</odoo>