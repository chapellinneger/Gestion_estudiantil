<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="portal_my_home_estudiantil_cards" inherit_id="portal.portal_my_home" priority="20">
            <xpath expr="//div[@id='portal_common_category']" position="after">
                <h3 class="my-3">Gestión Estudiantil</h3>
                <div class="o_portal_category row g-2 mt-3 mb-4">
                    
                    <t t-call="portal.portal_docs_entry">
                        <t t-set="title">Materias</t>
                        <t t-set="url" t-value="'/my/subjects'"/>
                        <t t-set="icon" t-value="'/portal/static/src/img/portal-connection.svg'"/> 
                        <t t-set="config_card" t-value="True"/>
                    </t>

                    <t t-call="portal.portal_docs_entry">
                        <t t-set="title">Notas</t>
                        <t t-set="url" t-value="'/my/grades'"/>
                        <t t-set="icon" t-value="'/portal/static/src/img/portal-connection.svg'"/>
                        <t t-set="config_card" t-value="True"/>
                    </t>

                    <t t-call="portal.portal_docs_entry">
                        <t t-set="title">Actividades</t>
                        <t t-set="url" t-value="'/my/activities'"/>
                        <t t-set="icon" t-value="'/portal/static/src/img/portal-connection.svg'"/>
                        <t t-set="config_card" t-value="True"/>
                    </t>

                    <t t-call="portal.portal_docs_entry">
                        <t t-set="title">Ausencias</t>
                        <t t-set="url" t-value="'/my/absences'"/>
                        <t t-set="icon" t-value="'/portal/static/src/img/portal-connection.svg'"/>
                        <t t-set="config_card" t-value="True"/>
                    </t>

                    <t t-call="portal.portal_docs_entry">
                        <t t-set="title">Secciones</t>
                        <t t-set="url" t-value="'/my/sections'"/>
                        <t t-set="icon" t-value="'/portal/static/src/img/portal-connection.svg'"/>
                        <t t-set="config_card" t-value="True"/>
                    </t>

                    <t t-call="portal.portal_docs_entry">
                        <t t-set="title">Profesores</t>
                        <t t-set="url" t-value="'/my/teachers'"/>
                        <t t-set="icon" t-value="'/portal/static/src/img/portal-addresses.svg'"/>
                        <t t-set="config_card" t-value="True"/>
                    </t>
                </div>
            </xpath>
        </template>

        <!-- 1. MATERIAS (Desde Secciones) -->
        <template id="portal_my_subjects_template" name="Mis Materias">
            <t t-call="portal.portal_layout">
                <div id="wrap" class="container mt-4">
                    <h3>Mis Materias Inscritas</h3>
                    <div class="card shadow-sm border-0 bg-white p-3">
                        <table class="table table-hover mb-0">
                            <thead class="table-primary">
                                <tr>
                                    <th>Materia</th>
                                    <th>Profesor</th>
                                    <th>Sección</th>
                                    <th>Estado</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="secciones" t-as="seccion">
                                    <tr>
                                        <td><strong t-esc="seccion.subject_id.name"/></td>
                                        <td><t t-esc="seccion.teacher_id.name if seccion.teacher_id else 'No asignado'"/></td>
                                        <td><t t-esc="seccion.name"/></td>
                                        <td><span class="badge bg-info" t-esc="seccion.state"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </div>
            </t>
        </template>

        <!-- 2. ACTIVIDADES (gestion.activity) -->
        <template id="portal_my_activities_template" name="Mis Actividades">
            <t t-call="portal.portal_layout">
                <div id="wrap" class="container mt-4">
                    <h3>Tareas y Actividades</h3>
                    <div class="row mt-3">
                        <t t-foreach="actividades" t-as="act">
                            <div class="col-md-6 mb-3">
                                <div class="card h-100 shadow-sm border-0">
                                    <div class="card-body">
                                        <h5 class="card-title text-primary" t-esc="act.name"/>
                                        <h6 class="card-subtitle mb-2 text-muted">
                                            Prof: <t t-esc="act.teacher_id.name"/>
                                        </h6>
                                        <div class="card-text text-muted mb-2">
                                            <t t-raw="act.description"/>
                                        </div>
                                        <small class="text-danger" t-if="act.date_deadline">
                                            Entrega: <span t-field="act.date_deadline"/>
                                        </small>
                                        <!-- Botón ficticio por ahora -->
                                        <div class="mt-3">
                                            <a t-attf-href="#" class="btn btn-sm btn-outline-primary">Ver Detalles</a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </div>
                </div>
            </t>
        </template>

        <!-- 3. NOTAS (grade.grade) -->
        <template id="portal_my_grades_template" name="Mis Notas">
            <t t-call="portal.portal_layout">
                <div id="wrap" class="container mt-4">
                    <h3>Historial de Notas</h3>
                    <div class="list-group mt-3">
                        <t t-if="not notas">
                            <div class="alert alert-info">No se encontraron notas registradas para su usuario.</div>
                        </t>
                        <t t-foreach="notas" t-as="nota">
                            <div class="list-group-item d-flex justify-content-between align-items-center border-0 shadow-sm mb-2 bg-white rounded">
                                <div>
                                    <h6 class="mb-0" t-esc="nota.activity_id.name"/>
                                    <small class="text-muted">Docente: <t t-esc="nota.teacher_id.name"/></small>
                                    <div t-if="nota.teacher_feedback" class="text-muted fst-italic mt-1" style="font-size: 0.9em;">
                                        "<t t-esc="nota.teacher_feedback"/>"
                                    </div>
                                </div>
                                <span t-attf-class="badge rounded-pill p-2 #{'bg-danger' if nota.score &lt; 10 else 'bg-success'}" style="min-width: 50px; font-size: 1.1em;">
                                    <t t-esc="nota.score"/>
                                </span>
                            </div>
                        </t>
                    </div>
                </div>
            </t>
        </template>

        <!-- 4. AUSENCIAS (gestion.attendance_line) -->
        <template id="portal_my_absences_template" name="Mis Ausencias">
            <t t-call="portal.portal_layout">
                <div id="wrap" class="container mt-4">
                    <h3>Registro de Asistencia</h3>
                    <div class="card shadow-sm border-0 bg-white p-3">
                        <table class="table table-striped mb-0">
                            <thead>
                                <tr>
                                    <th>Fecha</th>
                                    <th>Sección</th>
                                    <th>Estado</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="asistencias" t-as="asistencia">
                                    <tr>
                                        <td><span t-field="asistencia.attendance_id.date"/></td>
                                        <td><span t-esc="asistencia.attendance_id.section_id.name"/></td>
                                        <td>
                                            <span t-if="asistencia.present" class="badge bg-success">Presente</span>
                                            <span t-else="" class="badge bg-danger">Ausente</span>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </div>
            </t>
        </template>

        <!-- 5. SECCIONES (gestion.seccion) -->
        <template id="portal_my_sections_template" name="Mis Secciones">
            <t t-call="portal.portal_layout">
                <div id="wrap" class="container mt-4">
                    <h3>Mis Secciones</h3>
                    <div class="row row-cols-1 row-cols-md-2 g-4">
                        <t t-foreach="secciones" t-as="seccion">
                            <div class="col">
                                <div class="card h-100 shadow-sm">
                                    <div class="card-body">
                                        <h5 class="card-title" t-esc="seccion.name"/>
                                        <p class="card-text">
                                            <strong>Materia:</strong> <span t-esc="seccion.subject_id.name"/><br/>
                                            <strong>Profesor:</strong> <span t-esc="seccion.teacher_id.name"/><br/>
                                            <strong>Estado:</strong> <span class="badge bg-info" t-esc="seccion.state"/>
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </div>
                </div>
            </t>
        </template>

        <!-- 6. PROFESORES (gestion.teacher) -->
        <template id="portal_my_teachers_template" name="Mis Profesores">
            <t t-call="portal.portal_layout">
                <div id="wrap" class="container mt-4">
                    <h3>Mis Profesores</h3>
                    <div class="row row-cols-1 row-cols-md-3 g-4">
                        <t t-foreach="profesores" t-as="teacher">
                            <div class="col">
                                <div class="card h-100 text-center shadow-sm p-3">
                                    <div class="card-body">
                                        <div class="mb-3">
                                            <!-- Placeholder avatar or image if available -->
                                            <img t-if="teacher.image_1920" t-att-src="image_data_uri(teacher.image_1920)" class="rounded-circle img-fluid" style="width: 100px; height: 100px; object-fit: cover;"/>
                                            <img t-else="" src="/base/static/img/avatar.png" class="rounded-circle img-fluid" style="width: 100px; height: 100px;"/>
                                        </div>
                                        <h5 class="card-title" t-esc="teacher.name"/>
                                        <p class="card-text text-muted" t-esc="teacher.email"/>
                                        <p class="card-text" t-esc="teacher.phone"/>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </div>
                </div>
            </t>
        </template>

    </data>
</odoo>
