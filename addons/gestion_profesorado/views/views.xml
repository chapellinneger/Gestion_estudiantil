<odoo>
  <data>
    <record model="ir.ui.view" id="view_teacher_tree">
        <field name="name">res.users.tree.teacher</field>
        <field name="model">res.users</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="login" string="Correo"/>
            </list>
        </field>
    </record>

    <record model="ir.ui.view" id="view_teacher_form">
        <field name="name">res.users.form.teacher</field>
        <field name="model">res.users</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Nombre del Profesor"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Datos de Contacto">
                            <field name="login" string="Correo Electrónico"/>
                            <field name="is_teacher" invisible="1"/> 
                        </group>
                        <group string="Validación">
                            <field name="signature" widget="signature" string="Firma del Docente"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record model="ir.actions.act_window" id="gestion_profesorado.action_window">
      <field name="name">Profesores</field>
      <field name="res_model">res.users</field>
      <field name="view_mode">list,form</field>
      <field name="view_ids" eval="[(5, 0, 0), 
          (0, 0, {'view_mode': 'list', 'view_id': ref('view_teacher_tree')}), 
          (0, 0, {'view_mode': 'form', 'view_id': ref('view_teacher_form')})]"/>
      <field name="domain">[('is_teacher', '=', True)]</field>
      <field name="context">{'default_is_teacher': True}</field>
    </record>

    <menuitem name="Gestion Profesorado" id="gestion_profesorado.menu_root"/>
    <menuitem name="Profesores" id="gestion_profesorado.menu_1" parent="gestion_profesorado.menu_root" action="gestion_profesorado.action_window"/>
  </data>
</odoo>