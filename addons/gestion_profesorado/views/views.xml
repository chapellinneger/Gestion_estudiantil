<odoo>
  <data>
    <!-- Tree View for Teachers -->
    <record model="ir.ui.view" id="view_teacher_tree">
        <field name="name">gestion.teacher.tree</field>
        <field name="model">gestion.teacher</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="email"/>
                <field name="is_teacher"/>
            </list>
        </field>
    </record>

    <!-- Form View for Teachers -->
    <record model="ir.ui.view" id="view_teacher_form">
        <field name="name">gestion.teacher.form</field>
        <field name="model">gestion.teacher</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Nombre del Profesor"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Datos de Contacto">
                            <field name="partner_id" invisible="1"/>
                            <field name="email"/>
                            <field name="is_teacher" invisible="1"/> 
                            <field name="user_id" invisible="1"/>
                        </group>
                        <group string="Validación">
                            <field name="signature" widget="signature" string="Firma del Docente"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action for Teachers -->
    <record model="ir.actions.act_window" id="gestion_profesorado.action_window">
      <field name="name">Profesores</field>
      <field name="res_model">gestion.teacher</field>
      <field name="view_mode">list,form</field>
    </record>

    <menuitem name="Gestion Profesorado" id="gestion_profesorado.menu_root"/>
    <menuitem name="Profesores" id="gestion_profesorado.menu_1" parent="gestion_profesorado.menu_root" action="gestion_profesorado.action_window"/>
  </data>
</odoo>