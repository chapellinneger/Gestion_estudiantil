<odoo>
  <data>
    <!-- Explicit list view definition -->
    <record model="ir.ui.view" id="gestion_profesorado.profesor_list">
      <field name="name">gestion_profesorado.profesor.list</field>
      <field name="model">gestion_profesorado.profesor</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="description"/>
          <field name="active"/>
        </list>
      </field>
    </record>

    <!-- Form view -->
    <record model="ir.ui.view" id="gestion_profesorado.profesor_form">
      <field name="name">gestion_profesorado.profesor.form</field>
      <field name="model">gestion_profesorado.profesor</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <group>
              <field name="name"/>
              <field name="description"/>
              <field name="active"/>
            </group>
          </sheet>
        </form>
      </field>
    </record>

    <!-- Actions -->
    <record model="ir.actions.act_window" id="gestion_profesorado.action_window">
      <field name="name">Profesores</field>
      <field name="res_model">gestion_profesorado.profesor</field>
      <field name="view_mode">list,form</field>
    </record>

    <!-- Menu items -->
    <menuitem name="Gestion Profesorado" id="gestion_profesorado.menu_root"/>
    <menuitem name="Profesores" id="gestion_profesorado.menu_1" parent="gestion_profesorado.menu_root" action="gestion_profesorado.action_window"/>
  </data>
</odoo>
