<odoo>
    <template id="portal_actividad_page" name="Entregar Actividad">
        <t t-call="website.layout">
            <div class="container mt-4">
                <div class="row justify-content-center">
                    <div class="col-md-8">
                        <div class="card shadow">
                            <div class="card-header bg-primary text-white">
                                <h3 t-field="activity.name"/>
                            </div>
                            <div class="card-body">
                                <h5>Instrucciones:</h5>
                                <div t-field="activity.description" class="mb-4"/>
                                
                                <p><strong>Fecha límite: </strong> <span t-field="activity.date_deadline"/></p>

                                <hr/>

                                <div t-if="request.params.get('success')" class="alert alert-success">
                                    ¡Tu archivo ha sido enviado correctamente! El profesor ya puede revisarlo.
                                </div>

                                <form action="/gestion/actividad/subir" method="post" enctype="multipart/form-data">
                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                    <input type="hidden" name="activity_id" t-att-value="activity.id"/>
                                    
                                    <div class="mb-3">
                                        <label for="archivo_tarea" class="form-label">Subir archivo (PDF, Docx, etc.)</label>
                                        <input type="file" name="archivo_tarea" id="archivo_tarea" class="form-control" required="1"/>
                                    </div>
                                    
                                    <div class="d-grid">
                                        <button type="submit" class="btn btn-success">
                                            <i class="fa fa-upload"/> Enviar Tarea
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>