<odoo>
    <data>
        <record id="view_gestion_activity_list" model="ir.ui.view">
            <field name="name">gestion.activity.list</field>
            <field name="model">gestion.activity</field>
            <field name="arch" type="xml">
                <list string="Tareas">
                    <field name="name"/>
                    <field name="teacher_id"/>
                    <field name="date_deadline" widget="remaining_days"/> </list>
            </field>
        </record>

        <record id="view_gestion_activity_form" model="ir.ui.view">
            <field name="name">gestion.activity.form</field>
            <field name="model">gestion.activity</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <div class="oe_title">
                            <label for="name" string="Nombre de la Actividad"/>
                            <h1><field name="name" placeholder="Ej. Tarea 1: Introducción"/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="teacher_id" options="{'no_quick_create': True}"/>
                            </group>
                            <group>
                                <field name="date_deadline"/>
                            </group>
                        </group>
                        
                        <notebook>
                            <page string="Instrucciones" name="instructions">
                                <field name="description" placeholder="Escriba aquí las instrucciones..." widget="html"/>
                            </page>
                            <page string="Entregas de Alumnos" name="submissions">
                                <field name="submission_ids">
                                    <list editable="bottom">
                                        <field name="student_id"/>
                                        <field name="submission_date"/>
                                        <field name="file_name" column_invisible="True"/>
                                        <field name="file_data" filename="file_name" widget="binary"/>
                                        <field name="score"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_gestion_activity" model="ir.actions.act_window">
            <field name="name">Actividades Académicas</field>
            <field name="res_model">gestion.activity</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem id="menu_gestion_activity_submenu" 
                  name="Actividades" 
                  parent="gestion_profesorado.menu_root" 
                  action="action_gestion_activity"
                  sequence="20"/>
    </data>
</odoo>